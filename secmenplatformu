<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Seçmen Platformu</title>
  <meta name="description" content="Bulgaristan seçimleri için seçmen bilgilendirme, sandık sorgulama, otobüs ve araç paylaşımı platformu." />
  <style>
    :root {
      --bg: #f4f7fb;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --primary: #c62828;
      --primary-dark: #8e1b1b;
      --green: #1f7a3d;
      --blue: #1e5aa8;
      --gold: #d4a017;
      --border: #e5e7eb;
      --shadow: 0 10px 30px rgba(0,0,0,.08);
      --radius: 18px;
      --max: 1200px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
    }

    a { color: inherit; text-decoration: none; }

    .topbar {
      background: #fff3cd;
      color: #6b4f00;
      text-align: center;
      padding: 10px 14px;
      font-size: 14px;
      border-bottom: 1px solid #f1df9c;
    }

    .hero {
      background: linear-gradient(135deg, #0d3b8e 0%, #c62828 100%);
      color: white;
      padding: 56px 20px 40px;
    }

    .wrap {
      max-width: var(--max);
      margin: 0 auto;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.2fr .8fr;
      gap: 24px;
      align-items: center;
    }

    .badge {
      display: inline-block;
      background: rgba(255,255,255,.14);
      border: 1px solid rgba(255,255,255,.22);
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 13px;
      margin-bottom: 16px;
    }

    h1 {
      font-size: 44px;
      line-height: 1.1;
      margin: 0 0 14px;
    }

    .hero p {
      font-size: 18px;
      color: rgba(255,255,255,.92);
      margin: 0 0 22px;
      max-width: 700px;
    }

    .hero-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: none;
      border-radius: 14px;
      padding: 14px 18px;
      font-size: 15px;
      font-weight: bold;
      cursor: pointer;
      transition: .2s ease;
    }

    .btn:hover { transform: translateY(-1px); }
    .btn-primary { background: white; color: var(--primary); }
    .btn-secondary { background: rgba(255,255,255,.12); color: white; border: 1px solid rgba(255,255,255,.25); }
    .btn-green { background: var(--green); color: white; }
    .btn-blue { background: var(--blue); color: white; }
    .btn-gold { background: var(--gold); color: #222; }
    .btn-red { background: var(--primary); color: white; }
    .btn-dark { background: #111827; color: white; }

    .hero-note {
      font-size: 14px;
      color: rgba(255,255,255,.85);
    }

    .stats-card {
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.18);
      backdrop-filter: blur(6px);
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: var(--shadow);
    }

    .stats-card h3 {
      margin: 0 0 10px;
      font-size: 20px;
    }

    .big-number {
      font-size: 40px;
      font-weight: bold;
      margin: 10px 0;
    }

    .section {
      padding: 34px 20px;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 22px;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .grid-4 {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: var(--shadow);
    }

    .card h2, .card h3 {
      margin-top: 0;
    }

    .muted { color: var(--muted); }

    .field, select, textarea {
      width: 100%;
      padding: 14px 15px;
      border-radius: 12px;
      border: 1px solid #d1d5db;
      font-size: 15px;
      margin-bottom: 12px;
      background: white;
      font-family: inherit;
    }

    textarea {
      min-height: 110px;
      resize: vertical;
    }

    .mini-title {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: var(--muted);
      margin-bottom: 8px;
      font-weight: bold;
    }

    .info-list {
      padding-left: 18px;
      margin: 0;
    }

    .info-list li { margin-bottom: 8px; }

    .cta-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    .cta-box {
      border-radius: 16px;
      padding: 18px;
      color: white;
      min-height: 150px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      box-shadow: var(--shadow);
    }

    .red { background: linear-gradient(135deg, #d32f2f, #b71c1c); }
    .blue { background: linear-gradient(135deg, #1565c0, #0d47a1); }
    .green { background: linear-gradient(135deg, #2e7d32, #1b5e20); }
    .gold { background: linear-gradient(135deg, #f0c14b, #d4a017); color: #222; }

    .footer {
      background: #111827;
      color: #d1d5db;
      padding: 32px 20px;
      margin-top: 20px;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 20px;
    }

    .small { font-size: 14px; }

    .highlight {
      background: #eef5ff;
      border: 1px solid #cfe1ff;
      color: #133b74;
      padding: 12px 14px;
      border-radius: 12px;
      margin-top: 12px;
      font-size: 14px;
    }

    .result {
      margin-top: 14px;
      padding: 16px;
      border-radius: 14px;
      background: #f0fdf4;
      border: 1px solid #b7ebc6;
      color: #14532d;
    }

    .warn {
      margin-top: 14px;
      padding: 16px;
      border-radius: 14px;
      background: #fff7ed;
      border: 1px solid #fed7aa;
      color: #9a3412;
    }

    .trip-list {
      display: grid;
      gap: 12px;
      margin-top: 12px;
    }

    .trip-item {
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px;
      background: #fff;
    }

    .trip-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      font-weight: bold;
    }

    .pill {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 12px;
      background: #edf2ff;
      color: #224;
      margin-right: 6px;
      margin-top: 6px;
    }

    .admin-panel {
      display: none;
      margin-top: 18px;
      border-top: 1px dashed #cbd5e1;
      padding-top: 18px;
    }

    .table-wrap {
      overflow-x: auto;
      margin-top: 12px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 12px;
      overflow: hidden;
      font-size: 14px;
    }

    th, td {
      border: 1px solid #e5e7eb;
      padding: 10px;
      text-align: left;
      vertical-align: top;
    }

    th {
      background: #f8fafc;
    }

    .counter-box {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      padding: 16px;
    }

    .sticky-wa {
      position: fixed;
      right: 18px;
      bottom: 18px;
      z-index: 999;
    }

    .sticky-wa a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 58px;
      height: 58px;
      background: #25D366;
      color: white;
      border-radius: 999px;
      box-shadow: 0 10px 30px rgba(0,0,0,.18);
      font-size: 26px;
    }

    @media (max-width: 992px) {
      .hero-grid, .grid-2, .grid-3, .grid-4, .cta-row, .footer-grid {
        grid-template-columns: 1fr;
      }
      h1 { font-size: 34px; }
    }
  </style>
</head>
<body>
  <div class="topbar">
    SMS ile geldiyseniz aşağıdaki butonlarla sandık, ulaşım ve destek bilgilerine hemen ulaşabilirsiniz.
  </div>

  <header class="hero">
    <div class="wrap hero-grid">
      <div>
        <div class="badge">Bulgaristan Seçimleri Seçmen Bilgilendirme Platformu</div>
        <h1>Sandığınızı, ulaşım seçeneklerini ve destek noktalarını tek yerden öğrenin.</h1>
        <p>
          Türkiye’de veya Bulgaristan’da nerede oy kullanabileceğinizi öğrenin. Otobüs organizasyonlarını görün,
          bireysel araç paylaşımına katılın ve seçim günü için gerekli bilgilere hızlıca ulaşın.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#sorgu">📍 Nerede oy kullanabileceğimi öğren</a>
          <a class="btn btn-secondary" href="#ulasim">🚌 Ulaşım seçeneklerini gör</a>
          <a class="btn btn-secondary" href="#admin">📊 Yönetim Paneli</a>
        </div>
        <div class="hero-note">Her oy önemlidir. Katılım arttıkça temsil gücümüz artar.</div>
      </div>

      <div class="stats-card">
        <h3>Canlı Bilgilendirme Alanı</h3>
        <div class="big-number" id="heroCounter">0</div>
        <div class="muted">toplam kayıt ve talep oluşturuldu</div>
        <div class="highlight">
          Seçim günü yaklaşırken sandık yerinizi ve ulaşım planınızı önceden öğrenmeniz tavsiye edilir.
        </div>
      </div>
    </div>
  </header>

  <section class="section" id="sorgu">
    <div class="wrap grid-2">
      <div class="card">
        <div class="mini-title">Seçmen Sorgulama</div>
        <h2>Sandığımı Göster</h2>
        <p class="muted">Bilgilerinizi girin, oy kullanma yeriniz ve size uygun seçenekler görüntülensin.</p>

        <input id="fullName" class="field" type="text" placeholder="Ad Soyad" />
        <input id="birthDate" class="field" type="date" />
        <input id="egn" class="field" type="text" placeholder="Bulgaristan Kimlik No (EGN)" maxlength="10" />

        <select id="queryCity" class="field"></select>
        <select id="queryDistrict" class="field"></select>
        <select id="queryNeighborhood" class="field"></select>

        <button class="btn btn-red" style="width:100%;" onclick="showPollingResult()">📍 Sandığımı Göster</button>
        <div id="pollingResult"></div>
      </div>

      <div class="card">
        <div class="mini-title">Hızlı Erişim</div>
        <h2>Seçim Günü İçin Kısa Yol</h2>
        <div class="grid-3">
          <div>
            <h3>Türkiye’de Oy</h3>
            <p class="muted">Türkiye’de oy kullanabileceğiniz noktaları görüntüleyin.</p>
          </div>
          <div>
            <h3>Bulgaristan’da Oy</h3>
            <p class="muted">Sınır geçişi ve sandık bilgileriyle yol planınızı oluşturun.</p>
          </div>
          <div>
            <h3>Destek</h3>
            <p class="muted">WhatsApp ve iletişim kanallarıyla hızlı yardım alın.</p>
          </div>
        </div>
        <div style="margin-top:16px; display:flex; gap:10px; flex-wrap:wrap;">
          <a class="btn btn-green" href="#ulasim">🚌 Otobüs ile gitmek istiyorum</a>
          <a class="btn btn-blue" href="#arac">🚗 Araç paylaşımı ile git</a>
          <a class="btn btn-gold" href="#iletisim">💬 WhatsApp destek</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="cta-row">
        <div class="cta-box red">
          <div>
            <h3>Türkiye’de nerede oy kullanabilirim?</h3>
            <p>En yakın seçim merkezlerini görün.</p>
          </div>
          <a class="btn btn-primary" href="#sorgu">Merkezleri görüntüle</a>
        </div>
        <div class="cta-box blue" id="ulasim">
          <div>
            <h3>Otobüs organizasyonu</h3>
            <p>Şehrinizden planlanan ulaşım seçeneklerini inceleyin.</p>
          </div>
          <a class="btn btn-secondary" href="#ulasim-detay">Ulaşım detayları</a>
        </div>
        <div class="cta-box green" id="arac">
          <div>
            <h3>Araç paylaşımı</h3>
            <p>Mahallenden giden aracı bul veya aracında yer paylaş.</p>
          </div>
          <a class="btn btn-secondary" href="#arac-detay">Araç paylaşımına geç</a>
        </div>
        <div class="cta-box gold">
          <div>
            <h3>WhatsApp destek</h3>
            <p>Soruların için hızlı destek ve yönlendirme al.</p>
          </div>
          <a class="btn btn-primary" href="#iletisim">Destek al</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="ulasim-detay">
    <div class="wrap grid-2">
      <div class="card">
        <div class="mini-title">Ulaşım</div>
        <h2>Otobüs ile Gitmek İstiyorum</h2>
        <p class="muted">Şehir, ilçe ve kişi bilgilerinizi girin. Uygun organizasyon size bildirilsin.</p>

        <input id="busName" class="field" type="text" placeholder="Ad Soyad" />
        <input id="busPhone" class="field" type="text" placeholder="Telefon" />
        <select id="transportCity" class="field"></select>
        <select id="transportDistrict" class="field"></select>
        <input id="transportPeople" class="field" type="number" min="1" placeholder="Kaç kişi gidecek?" />
        <textarea id="busNote" class="field" placeholder="Ek not (isteğe bağlı)"></textarea>

        <button class="btn btn-green" style="width:100%;" onclick="createBusRequest()">🚌 Ulaşım Kaydı Oluştur</button>
        <div id="busResult"></div>

        <div class="trip-list" id="busRoutesList"></div>
      </div>

      <div class="card" id="arac-detay">
        <div class="mini-title">Araç Paylaşımı</div>
        <h2>Bireysel Araçlarla Yolculuk</h2>
        <p class="muted">Mahallenden giden aracı bul veya kendi aracında yer aç.</p>

        <input id="carName" class="field" type="text" placeholder="Ad Soyad" />
        <input id="carPhone" class="field" type="text" placeholder="Telefon" />

        <select id="carMode" class="field">
          <option value="Araç Arıyorum">Araç Arıyorum</option>
          <option value="Aracımda Yer Var">Aracımda Yer Var</option>
        </select>

        <select id="carCity" class="field"></select>
        <select id="carDistrict" class="field"></select>
        <select id="carNeighborhood" class="field"></select>

        <select id="borderGate" class="field">
          <option value="Kapıkule">Kapıkule</option>
          <option value="Hamzabeyli">Hamzabeyli</option>
          <option value="Dereköy">Dereköy</option>
        </select>

        <input id="carTime" class="field" type="time" />
        <input id="carSeats" class="field" type="number" min="1" placeholder="Boş koltuk sayısı / ihtiyaç sayısı" />
        <textarea id="carNote" class="field" placeholder="Ek not (isteğe bağlı)"></textarea>

        <button class="btn btn-blue" style="width:100%;" onclick="handleCarAction()">🚗 İşlemi Uygula</button>
        <div id="carResult"></div>

        <div class="trip-list" id="tripList"></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap grid-2">
      <div class="card">
        <div class="mini-title">Bilgilendirme</div>
        <h2>Oy Kullanma İçin Gerekli Bilgiler</h2>
        <ul class="info-list">
          <li>Oy kullanmak için Bulgaristan vatandaşı olmanız gerekir.</li>
          <li>Geçerli kimlik veya pasaport yanınızda bulunmalıdır.</li>
          <li>Sandık yerinizi önceden öğrenmeniz zaman kazandırır.</li>
          <li>Ulaşım planlamasını seçim gününden önce yapmanız önerilir.</li>
        </ul>
      </div>

      <div class="card">
        <div class="mini-title">Güven</div>
        <h2>Bilgileriniz Güvende</h2>
        <p class="muted">
          Bu platform, seçmenlerin doğru bilgiye hızlı erişmesi için hazırlanmıştır. Girilen bilgiler yalnızca yönlendirme
          ve bilgilendirme amaçlı kullanılacaktır.
        </p>
        <div class="highlight">Kişisel verileriniz bu demo sürümde tarayıcı hafızasında saklanır. Gerçek üretim sürümünde sunucu/veritabanı bağlantısı kurulmalıdır.</div>
      </div>
    </div>
  </section>

  <section class="section" id="admin">
    <div class="wrap">
      <div class="card">
        <div class="mini-title">Yönetim</div>
        <h2>Admin Paneli</h2>
        <p class="muted">Bu panel demo amaçlıdır. Şifreyi girince tarayıcı içinde kayıtları listeler.</p>

        <div class="grid-4">
          <div class="counter-box">
            <div class="mini-title">Seçmen Sorgu</div>
            <h3 id="countPolling">0</h3>
          </div>
          <div class="counter-box">
            <div class="mini-title">Otobüs Talebi</div>
            <h3 id="countBus">0</h3>
          </div>
          <div class="counter-box">
            <div class="mini-title">Araç Paylaşımı</div>
            <h3 id="countCar">0</h3>
          </div>
          <div class="counter-box">
            <div class="mini-title">Toplam</div>
            <h3 id="countTotal">0</h3>
          </div>
        </div>

        <div style="margin-top:16px;">
          <input id="adminPassword" class="field" type="password" placeholder="Admin şifresi" />
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <button class="btn btn-dark" onclick="toggleAdminPanel()">🔐 Paneli Aç</button>
            <button class="btn btn-gold" onclick="exportData()">⬇️ Verileri İndir</button>
            <button class="btn btn-red" onclick="clearAllData()">🗑️ Tüm Kayıtları Sil</button>
          </div>
        </div>

        <div id="adminMessage"></div>

        <div id="adminPanel" class="admin-panel">
          <h3>Seçmen Sorguları</h3>
          <div class="table-wrap" id="pollingTableWrap"></div>

          <h3 style="margin-top:20px;">Otobüs Talepleri</h3>
          <div class="table-wrap" id="busTableWrap"></div>

          <h3 style="margin-top:20px;">Araç Paylaşımı Kayıtları</h3>
          <div class="table-wrap" id="carTableWrap"></div>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer" id="iletisim">
    <div class="wrap footer-grid">
      <div>
        <h3 style="margin-top:0; color:white;">Seçmen Platformu</h3>
        <p class="small">Bulgaristan seçimleri için seçmen bilgilendirme, sandık sorgulama, ulaşım ve destek platformu.</p>
      </div>
      <div>
        <h4 style="color:white;">Hızlı Linkler</h4>
        <p class="small"><a href="#sorgu">Sandık Sorgulama</a></p>
        <p class="small"><a href="#ulasim">Ulaşım Seçenekleri</a></p>
        <p class="small"><a href="#arac">Araç Paylaşımı</a></p>
      </div>
      <div>
        <h4 style="color:white;">İletişim</h4>
        <p class="small">WhatsApp Destek: +90 5xx xxx xx xx</p>
        <p class="small">E-posta: destek@secmenplatformu.com</p>
      </div>
    </div>
  </footer>

  <div class="sticky-wa">
    <a href="https://wa.me/905000000000?text=Merhaba%20Se%C3%A7men%20Platformu%20destek%20ekibi%2C%20bilgi%20almak%20istiyorum." target="_blank" aria-label="WhatsApp">💬</a>
  </div>

