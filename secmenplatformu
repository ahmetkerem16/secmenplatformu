    const busRoutes = [
      { city: "Bursa", district: "Osmangazi", departure: "06:00", gate: "Kapıkule", seats: 14 },
      { city: "İstanbul", district: "Esenyurt", departure: "05:30", gate: "Kapıkule", seats: 22 },
      { city: "İzmir", district: "Buca", departure: "22:30", gate: "Hamzabeyli", seats: 11 },
      { city: "Tekirdağ", district: "Çorlu", departure: "07:00", gate: "Kapıkule", seats: 9 }
    ];

    const defaultTrips = [
      { from: "Bursa / Yıldırım / Erikli", to: "Kapıkule", seats: 2, time: "05:45", type: "Aracımda Yer Var", name: "Örnek Kayıt", phone: "-" },
      { from: "İstanbul / Esenyurt / Mehterçeşme", to: "Kapıkule", seats: 3, time: "04:30", type: "Aracımda Yer Var", name: "Örnek Kayıt", phone: "-" },
      { from: "Tekirdağ / Çorlu / Muhittin", to: "Kapıkule", seats: 1, time: "06:15", type: "Aracımda Yer Var", name: "Örnek Kayıt", phone: "-" },
      { from: "Bursa / Osmangazi / Demirtaş", to: "Hamzabeyli", seats: 2, time: "23:00", type: "Aracımda Yer Var", name: "Örnek Kayıt", phone: "-" }
    ];

    const pollingCenters = [
      { city: "Bursa", location: "Bursa Başkonsolosluk Geçici Seçim Noktası", address: "Nilüfer / Bursa" },
      { city: "İstanbul", location: "İstanbul Konsolosluk Seçim Merkezi", address: "Şişli / İstanbul" },
      { city: "İzmir", location: "İzmir Seçim Destek Noktası", address: "Konak / İzmir" },
      { city: "Tekirdağ", location: "Çorlu Bölgesel Destek Masası", address: "Çorlu / Tekirdağ" },
      { city: "Kocaeli", location: "Kocaeli Bölgesel Seçim Destek Noktası", address: "İzmit / Kocaeli" }
    ];

    function getStorage(key, fallback) {
      const raw = localStorage.getItem(key);
      return raw ? JSON.parse(raw) : fallback;
    }

    function setStorage(key, value) {
      localStorage.setItem(key, JSON.stringify(value));
    }

    function getPollingRecords() {
      return getStorage("pollingRecords", []);
    }

    function getBusRecords() {
      return getStorage("busRecords", []);
    }

    function getCarRecords() {
      return getStorage("carRecords", []);
    }

    function setPollingRecords(list) {
      setStorage("pollingRecords", list);
    }

    function setBusRecords(list) {
      setStorage("busRecords", list);
    }

    function setCarRecords(list) {
      setStorage("carRecords", list);
    }

    function fillSelect(selectId, options, placeholder) {
      const select = document.getElementById(selectId);
      select.innerHTML = "";
      const first = document.createElement("option");
      first.value = "";
      first.textContent = placeholder;
      select.appendChild(first);
      options.forEach(opt => {
        const o = document.createElement("option");
        o.value = opt;
        o.textContent = opt;
        select.appendChild(o);
      });
    }

    function setupCityDistrictNeighborhood(cityId, districtId, neighborhoodId) {
      fillSelect(cityId, Object.keys(data), "Şehir seçin");
      fillSelect(districtId, [], "İlçe seçin");
      if (neighborhoodId) fillSelect(neighborhoodId, [], "Mahalle seçin");

      document.getElementById(cityId).addEventListener("change", function () {
        const city = this.value;
        const districts = city ? Object.keys(data[city]) : [];
        fillSelect(districtId, districts, "İlçe seçin");
        if (neighborhoodId) fillSelect(neighborhoodId, [], "Mahalle seçin");
        if (cityId === "transportCity") renderBusRoutes();
        if (cityId === "carCity") renderTrips();
      });

      document.getElementById(districtId).addEventListener("change", function () {
        if (!neighborhoodId) {
          if (districtId === "transportDistrict") renderBusRoutes();
          return;
        }
        const city = document.getElementById(cityId).value;
        const district = this.value;
        const neighborhoods = city && district ? data[city][district] : [];
        fillSelect(neighborhoodId, neighborhoods, "Mahalle seçin");
        if (districtId === "carDistrict") renderTrips();
      });

      if (neighborhoodId) {
        document.getElementById(neighborhoodId).addEventListener("change", function () {
          if (neighborhoodId === "carNeighborhood") renderTrips();
        });
      }
    }

    function nowString() {
      return new Date().toLocaleString("tr-TR");
    }

    function updateCounters() {
      const polling = getPollingRecords().length;
      const bus = getBusRecords().length;
      const car = getCarRecords().length;
      const total = polling + bus + car;

      document.getElementById("countPolling").textContent = polling;
      document.getElementById("countBus").textContent = bus;
      document.getElementById("countCar").textContent = car;
      document.getElementById("countTotal").textContent = total;
      document.getElementById("heroCounter").textContent = total;
    }

    function showPollingResult() {
      const fullName = document.getElementById("fullName").value.trim();
      const birthDate = document.getElementById("birthDate").value;
      const egn = document.getElementById("egn").value.trim();
      const city = document.getElementById("queryCity").value;
      const district = document.getElementById("queryDistrict").value;
      const neighborhood = document.getElementById("queryNeighborhood").value;

      if (!fullName || !birthDate || !egn || !city || !district || !neighborhood) {
        document.getElementById("pollingResult").innerHTML = `<div class="warn">Lütfen tüm seçmen sorgulama alanlarını doldurun.</div>`;
        return;
      }

      const center = pollingCenters.find(p => p.city === city) || pollingCenters[0];

      document.getElementById("pollingResult").innerHTML = `
        <div class="result">
          <strong>${fullName}</strong> için önerilen kayıt bulundu.<br><br>
          <strong>Şehir:</strong> ${city}<br>
          <strong>İlçe:</strong> ${district}<br>
          <strong>Mahalle:</strong> ${neighborhood}<br>
          <strong>Oy Kullanma Merkezi:</strong> ${center.location}<br>
          <strong>Adres:</strong> ${center.address}<br><br>
          <span>Ulaşım seçeneklerini aşağıdan inceleyebilirsiniz.</span>
        </div>
      `;

      const records = getPollingRecords();
      records.unshift({
        name: fullName,
        birthDate,
        egn,
        city,
        district,
        neighborhood,
        center: center.location,
        address: center.address,
        createdAt: nowString()
      });
      setPollingRecords(records);
      updateCounters();
      renderAdminTables();
    }

    function renderBusRoutes() {
      const city = document.getElementById("transportCity").value;
      const district = document.getElementById("transportDistrict").value;
      const list = document.getElementById("busRoutesList");

      const filtered = busRoutes.filter(r => {
        if (city && r.city !== city) return false;
        if (district && r.district !== district) return false;
        return true;
      });

      if (!filtered.length) {
        list.innerHTML = `<div class="highlight">Bu seçim için seçilen bölgeye ait planlanmış otobüs kaydı şu an görünmüyor.</div>`;
        return;
      }

      list.innerHTML = filtered.map(r => `
        <div class="trip-item">
          <div class="trip-top">
            <span>${r.city} / ${r.district}</span>
            <span>${r.departure}</span>
          </div>
          <div class="muted" style="margin-top:6px;">Sınır Kapısı: ${r.gate}</div>
          <div class="pill">${r.seats} boş koltuk</div>
        </div>
      `).join("");
    }

    function createBusRequest() {
      const name = document.getElementById("busName").value.trim();
      const phone = document.getElementById("busPhone").value.trim();
      const city = document.getElementById("transportCity").value;
      const district = document.getElementById("transportDistrict").value;
      const people = document.getElementById("transportPeople").value;
      const note = document.getElementById("busNote").value.trim();

      if (!name || !phone || !city || !district || !people) {
        document.getElementById("busResult").innerHTML = `<div class="warn">Lütfen ad soyad, telefon, şehir, ilçe ve kişi sayısını girin.</div>`;
        return;
      }

      const records = getBusRecords();
      records.unshift({
        name,
        phone,
        city,
        district,
        people,
        note,
        createdAt: nowString()
      });
      setBusRecords(records);

      document.getElementById("busResult").innerHTML = `
        <div class="result">
          ${city} / ${district} için <strong>${people}</strong> kişilik ulaşım talebiniz oluşturuldu.<br>
          Kayıt yönetim paneline işlendi.
        </div>
      `;

      document.getElementById("busName").value = "";
      document.getElementById("busPhone").value = "";
      document.getElementById("transportPeople").value = "";
      document.getElementById("busNote").value = "";

      updateCounters();
      renderAdminTables();
    }

    function getAllTrips() {
      const saved = getCarRecords().map(item => ({
        from: `${item.city} / ${item.district} / ${item.neighborhood}`,
        to: item.borderGate,
        seats: item.seats,
        time: item.time,
        type: item.mode,
        name: item.name,
        phone: item.phone
      }));
      return [...saved, ...defaultTrips];
    }

    function renderTrips() {
      const city = document.getElementById("carCity").value;
      const district = document.getElementById("carDistrict").value;
      const neighborhood = document.getElementById("carNeighborhood").value;
      const gate = document.getElementById("borderGate").value;
      const list = document.getElementById("tripList");

      const trips = getAllTrips();

      const filtered = trips.filter(t => {
        if (city && !t.from.startsWith(city)) return false;
        if (district && !t.from.includes("/ " + district + " /")) return false;
        if (neighborhood && !t.from.endsWith("/ " + neighborhood)) return false;
        if (gate && t.to !== gate) return false;
        return true;
      });

      if (!filtered.length) {
        list.innerHTML = `<div class="highlight">Seçtiğiniz kriterlere uygun aktif araç paylaşımı kaydı bulunamadı.</div>`;
        return;
      }

      list.innerHTML = filtered.map(t => `
        <div class="trip-item">
          <div class="trip-top">
            <span>${t.from}</span>
            <span>${t.time || "-"}</span>
          </div>
          <div class="muted" style="margin-top:6px;">Varış sınır kapısı: ${t.to}</div>
          <div class="pill">${t.type}</div>
          <div class="pill">${t.seats} kişi</div>
          <div class="pill">${t.name}</div>
        </div>
      `).join("");
    }

    function handleCarAction() {
      const name = document.getElementById("carName").value.trim();
      const phone = document.getElementById("carPhone").value.trim();
      const mode = document.getElementById("carMode").value;
      const city = document.getElementById("carCity").value;
      const district = document.getElementById("carDistrict").value;
      const neighborhood = document.getElementById("carNeighborhood").value;
      const borderGate = document.getElementById("borderGate").value;
      const time = document.getElementById("carTime").value;
      const seats = document.getElementById("carSeats").value;
      const note = document.getElementById("carNote").value.trim();

      if (!name || !phone || !city || !district || !neighborhood || !time || !seats) {
        document.getElementById("carResult").innerHTML = `<div class="warn">Lütfen ad soyad, telefon, şehir, ilçe, mahalle, saat ve sayı alanlarını doldurun.</div>`;
        return;
      }

      const records = getCarRecords();
      records.unshift({
        name,
        phone,
        mode,
        city,
        district,
        neighborhood,
        borderGate,
        time,
        seats,
        note,
        createdAt: nowString()
      });
      setCarRecords(records);

      document.getElementById("carResult").innerHTML = `
        <div class="result">
          <strong>${mode}</strong> kaydınız oluşturuldu.<br>
          <strong>Bölge:</strong> ${city} / ${district} / ${neighborhood}<br>
          <strong>Sınır Kapısı:</strong> ${borderGate}<br>
          <strong>Saat:</strong> ${time}<br>
          <strong>Sayı:</strong> ${seats}<br><br>
          Kayıt sistemde görüntülenmeye hazır.
        </div>
      `;

      document.getElementById("carName").value = "";
      document.getElementById("carPhone").value = "";
      document.getElementById("carTime").value = "";
      document.getElementById("carSeats").value = "";
      document.getElementById("carNote").value = "";

      updateCounters();
      renderTrips();
      renderAdminTables();
    }

    function arrayToTable(list, headersMap) {
      if (!list.length) {
        return `<div class="highlight">Kayıt bulunmuyor.</div>`;
      }

      const headers = Object.keys(headersMap);
      const th = headers.map(h => `<th>${headersMap[h]}</th>`).join("");
      const rows = list.map(item => {
        return `<tr>${headers.map(h => `<td>${item[h] ?? ""}</td>`).join("")}</tr>`;
      }).join("");

      return `<table><thead><tr>${th}</tr></thead><tbody>${rows}</tbody></table>`;
    }

    function renderAdminTables() {
      document.getElementById("pollingTableWrap").innerHTML = arrayToTable(getPollingRecords(), {
        name: "Ad Soyad",
        birthDate: "Doğum Tarihi",
        egn: "EGN",
        city: "Şehir",
        district: "İlçe",
        neighborhood: "Mahalle",
        center: "Merkez",
        address: "Adres",
        createdAt: "Tarih"
      });

      document.getElementById("busTableWrap").innerHTML = arrayToTable(getBusRecords(), {
        name: "Ad Soyad",
        phone: "Telefon",
        city: "Şehir",
        district: "İlçe",
        people: "Kişi",
        note: "Not",
        createdAt: "Tarih"
      });

      document.getElementById("carTableWrap").innerHTML = arrayToTable(getCarRecords(), {
        name: "Ad Soyad",
        phone: "Telefon",
        mode: "Tür",
        city: "Şehir",
        district: "İlçe",
        neighborhood: "Mahalle",
        borderGate: "Sınır Kapısı",
        time: "Saat",
        seats: "Sayı",
        note: "Not",
        createdAt: "Tarih"
      });
    }

    function toggleAdminPanel() {
      const password = document.getElementById("adminPassword").value;
      const panel = document.getElementById("adminPanel");
      const msg = document.getElementById("adminMessage");

      if (password !== ADMIN_PASSWORD) {
        msg.innerHTML = `<div class="warn">Şifre hatalı.</div>`;
        panel.style.display = "none";
        return;
      }

      msg.innerHTML = `<div class="result">Admin paneli açıldı.</div>`;
      panel.style.display = "block";
      renderAdminTables();
    }

    function exportData() {
      const data = {
        pollingRecords: getPollingRecords(),
        busRecords: getBusRecords(),
        carRecords: getCarRecords()
      };

      const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = "secmenplatformu-kayitlar.json";
      a.click();
    }

    function clearAllData() {
      const password = document.getElementById("adminPassword").value;
      if (password !== ADMIN_PASSWORD) {
        document.getElementById("adminMessage").innerHTML = `<div class="warn">Tüm kayıtları silmek için doğru admin şifresi girin.</div>`;
        return;
      }

      localStorage.removeItem("pollingRecords");
      localStorage.removeItem("busRecords");
      localStorage.removeItem("carRecords");

      document.getElementById("adminMessage").innerHTML = `<div class="result">Tüm kayıtlar silindi.</div>`;
      document.getElementById("pollingResult").innerHTML = "";
      document.getElementById("busResult").innerHTML = "";
      document.getElementById("carResult").innerHTML = "";
      updateCounters();
      renderTrips();
      renderAdminTables();
    }

    setupCityDistrictNeighborhood("queryCity", "queryDistrict", "queryNeighborhood");
    setupCityDistrictNeighborhood("transportCity", "transportDistrict", null);
    setupCityDistrictNeighborhood("carCity", "carDistrict", "carNeighborhood");

    renderBusRoutes();
    renderTrips();
    updateCounters();
    renderAdminTables();
  </script>
</body>
</html>
